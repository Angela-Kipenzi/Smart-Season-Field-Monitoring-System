{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build",
  "framework": null,
  "builds": [
    {
      "src": "artifacts/smartseason/**",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    },
    {
      "src": "artifacts/api-server/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/smartseason/index.html"
    }
  ]
}